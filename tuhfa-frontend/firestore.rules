rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default catch-all security safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // To prevent privilege escalation, custom admin lookup
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity-specific validators
    function isValidUser(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.username is string && data.username.size() >= 3 && data.username.size() <= 50 &&
             data.name is string && data.name.size() >= 2 && data.name.size() <= 100 &&
             data.phone is string && data.phone.size() <= 20 &&
             data.isAdmin is bool;
    }

    function isValidOrder(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.userId is string && data.userId.size() <= 128 &&
             data.customerName is string && data.customerName.size() >= 2 && data.customerName.size() <= 100 &&
             data.phone is string && data.phone.size() <= 20 &&
             data.occasionType is string && data.occasionType.size() <= 50 &&
             data.mainColor is string && data.mainColor.size() <= 50 &&
             data.customText is string && data.customText.size() <= 200 &&
             data.details is string && data.details.size() <= 1000 &&
             data.status is string && (data.status == 'pending' || data.status == 'confirmed' || data.status == 'preparing' || data.status == 'delivered' || data.status == 'canceled') &&
             data.createdAt is string && data.createdAt.size() <= 50;
    }

    function isValidNotification(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.userId is string && data.userId.size() <= 128 &&
             data.title is string && data.title.size() <= 200 &&
             data.message is string && data.message.size() <= 500 &&
             data.isRead is bool;
    }

    // Match rules for each cataloged collection from firebase-blueprint

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin(); // only admins can search users list

      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
      
      allow update: if isSignedIn() && (
        (request.auth.uid == userId && isValidUser(incoming()) && incoming().isAdmin == existing().isAdmin) || 
        isAdmin()
      );
      
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow get: if isSignedIn() && (request.auth.uid == existing().userId || isAdmin());
      allow list: if isSignedIn() && (isAdmin() || (resource.data.userId == request.auth.uid));
      
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidOrder(incoming());
      
      allow update: if isSignedIn() && (
        isAdmin() || 
        (request.auth.uid == existing().userId && isValidOrder(incoming()) && incoming().userId == existing().userId && 
         incoming().diff(existing()).affectedKeys().hasOnly(['customerName', 'phone', 'occasionType', 'mainColor', 'customText', 'details', 'metroStation']))
      );
      
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow get: if isSignedIn() && (request.auth.uid == existing().userId || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isAdmin() || (isSignedIn() && incoming().userId == request.auth.uid && isValidNotification(incoming()));
      allow update: if isSignedIn() && (request.auth.uid == existing().userId || isAdmin());
      allow delete: if isSignedIn() && (request.auth.uid == existing().userId || isAdmin());
    }
  }
}
