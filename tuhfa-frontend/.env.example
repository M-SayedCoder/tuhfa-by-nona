# Frontend Environment Variables
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# API Base URL Configuration
# ✅ Development: Use relative /api (proxied by Vite to http://localhost:3001/api)
# ✅ Production: Use full Railway URL (https://tuhfa-by-nona-production.up.railway.app/api)
# 
# .env.local → /api (development - Vite proxy)
# .env.production → https://tuhfa-by-nona-production.up.railway.app/api (Vercel deployment)

VITE_API_URL=/api
